# ============================================================
# Variables de entorno — plantilla. Copia este archivo como
# .env.local y rellena los valores reales del cliente.
#   cp .env.example .env.local
# NUNCA subas .env.local a git (ya está en .gitignore).
# El soporte privado puede revisar estas variables con el diagnóstico de
# producción sin exponer valores ni secretos reales.
# ============================================================

# --- Supabase (Proyecto del cliente · Project Settings → API) ---
# URL del proyecto, ej. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Clave pública (anon). Se usa en el navegador. Reservada para realtime futuro.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clave secreta (service_role). SOLO servidor. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Contraseñas de acceso por rol (panel privado) ---
# Cada rol entra con su clave. Pon claves fuertes y distintas por cliente.
ORDERS_OWNER_PASSWORD=
ORDERS_ADMIN_PASSWORD=
# Alias opcional de admin (compatibilidad). Puedes dejarlo vacío.
ADMIN_PASSWORD=
ORDERS_MANAGER_PASSWORD=
ORDERS_CASHIER_PASSWORD=
ORDERS_WAITER_PASSWORD=
ORDERS_KITCHEN_PASSWORD=
ORDERS_DELIVERY_PASSWORD=
ORDERS_SUPPORT_PASSWORD=
ORDERS_PROVIDER_PASSWORD=

# --- Pagos en línea (Stripe) · OPCIONAL ---
# Si se dejan vacías, los pagos en línea quedan DESACTIVADOS (todo lo demás
# funciona igual). Para activarlos, crea una cuenta en stripe.com y pega:
STRIPE_SECRET_KEY=
# Secreto del webhook (Stripe Dashboard → Developers → Webhooks → endpoint
# /api/payments/webhook, evento checkout.session.completed):
STRIPE_WEBHOOK_SECRET=
# Moneda del cobro online (Stripe no soporta VES). Por defecto usd:
STRIPE_CURRENCY=usd
# URL pública del sitio (para los enlaces de éxito/cancelación):
NEXT_PUBLIC_SITE_URL=

# --- Protección de APIs públicas y cargas · OPCIONAL ---
# Rate limit en memoria. En serverless no es perfecto entre instancias, pero
# corta abuso básico y evita que el store crezca indefinidamente.
RATE_LIMIT_MAX_KEYS=10000
# Hosts extra permitidos para llamadas mutantes cuando uses dominios alternos,
# previews o subdominios propios. Separar por coma. Normalmente se deja vacío.
# Ejemplo: ALLOWED_API_ORIGINS=https://preview.vercel.app,admin.tudominio.com
ALLOWED_API_ORIGINS=
# Registra eventos de seguridad en logs/monitoreo sin guardar IP cruda.
SECURITY_EVENT_LOGGING=true

# Límites por tamaño de request. Sirven como primer corte anti-abuso cuando
# el navegador/proxy envía content-length. Si el header no viene, no se bloquea.
ORDERS_POST_MAX_BYTES=9000000
PAYMENT_PROOF_POST_MAX_BYTES=8000000
PUBLIC_OPEN_ACCOUNT_POST_MAX_BYTES=32000
MENU_IMAGE_UPLOAD_MAX_BYTES=5500000
# Límites reales del contenido de imagen base64 ya decodificado.
# Sólo se aceptan JPG, PNG o WEBP para evitar formatos inseguros.
ORDER_ATTACHMENT_IMAGE_MAX_BYTES=6000000
PAYMENT_PROOF_IMAGE_MAX_BYTES=5500000
MENU_IMAGE_UPLOAD_BYTES=4800000

# Límites para rutas privadas mutantes (configuración, menú, inventario,
# personal, sucursales, cuentas abiertas y revisiones). Ajusta solo si un
# cliente maneja payloads internos más grandes de lo normal.
PRIVATE_API_MUTATION_MAX_BYTES=2000000
MENU_PRODUCTS_MUTATION_MAX_BYTES=3000000
INVENTORY_MUTATION_MAX_BYTES=2000000


# --- Rutas internas sensibles · OPCIONAL ---
# Límites de payload para acciones internas puntuales. Normalmente no hace
# falta cambiarlos; existen para cortar requests anómalos antes de leer JSON.
ORDER_DETAIL_MUTATION_MAX_BYTES=64000
ORDER_PAYMENT_MUTATION_MAX_BYTES=64000
DAY_CLOSE_POST_MAX_BYTES=2000000

# --- Tasa pública / protección anti-spam · OPCIONAL ---
# Cache corto en memoria para no consultar BCV/DolarApi en cada carga pública.
# En serverless no es persistente entre instancias, pero reduce spam inicial.
EXCHANGE_RATE_CACHE_MS=60000
EXCHANGE_RATE_FALLBACK_CACHE_MS=15000

# --- Monitoreo de errores · OPCIONAL ---
# Base segura incluida: los errores de rutas críticas se registran en logs del servidor.
# Dejar vacío no rompe el build ni el funcionamiento local.
# Para conectar Sentry después, instala @sentry/nextjs y coloca el DSN real.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_DEBUG=false
SENTRY_AUTH_TOKEN=
MONITORING_LOG_ERRORS=true
MONITORING_REMOTE_DISABLED=false

# ============================================================
# Backend actual: Supabase.
# No agregues claves antiguas de integraciones obsoletas en producción.
# ============================================================

# ============================================================
# WhatsApp Business Cloud API (Meta) — encuesta post-venta automática.
# Se obtienen en developers.facebook.com → tu app → WhatsApp → API Setup:
#   WHATSAPP_BUSINESS_TOKEN    = token permanente (System User token)
#   WHATSAPP_BUSINESS_PHONE_ID = "Phone number ID" del número del negocio
#   WHATSAPP_TEMPLATE_LANG     = idioma de las plantillas (es)
#
# --- Encuesta COMPLETA con FORMULARIO (WhatsApp Flows) ---
# Modo MÁS completo: formulario nativo dentro del chat (varias preguntas 1–5
# + comentario), como la página /encuesta pero sin link. Requiere un Flow
# publicado en Meta y una plantilla con botón tipo "flow" que lo lance
# (cuerpo con {{1}} = nombre del cliente). Tiene la mayor prioridad:
#   WHATSAPP_SURVEY_FLOW_TEMPLATE = nombre de esa plantilla con botón de flow
# (usa el mismo webhook, verify token y App Secret de abajo)
#
# --- Encuesta CON BOTONES (se contesta con un toque, sin link) ---
# Modo preferido. El cliente toca Excelente/Bien/Malo y su elección vuelve por
# el webhook. Requiere una plantilla de botones de respuesta rápida aprobada
# en Meta (cuerpo con {{1}} = nombre del cliente, 3 botones QUICK_REPLY):
#   WHATSAPP_SURVEY_BUTTON_TEMPLATE = nombre de esa plantilla de botones
#   WHATSAPP_WEBHOOK_VERIFY_TOKEN   = texto secreto que también pegas en Meta
#                                     (Configuration → Verify token)
#   WHATSAPP_APP_SECRET             = App Secret (valida la firma del webhook)
# Callback URL en Meta = https://<tu-dominio>/api/whatsapp/webhook
#
# --- Encuesta CON LINK (respaldo, abre página web) ---
# Sólo se usa si NO hay plantilla de botones configurada:
#   WHATSAPP_SURVEY_TEMPLATE   = plantilla con link ({{1}} = nombre, {{2}} = link)
#
# Todo vacío = el envío automático queda apagado; el botón manual sigue.
# ============================================================
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_TEMPLATE_LANG=es
WHATSAPP_SURVEY_FLOW_TEMPLATE=
WHATSAPP_SURVEY_BUTTON_TEMPLATE=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_SURVEY_TEMPLATE=
